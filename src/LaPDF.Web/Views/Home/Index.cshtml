@{
    ViewData["Title"] = "LaPDF";
}

<div class="container py-5">
    <!-- HERO -->
    <section class="hero-section text-center py-5">
        <h1 class="hero-title">
            <span class="text-light fw-light">Toda ferramenta que você precisa</span><br />
            <span class="text-gradient fw-bold">para trabalhar com PDFs</span>
        </h1>
        <p class="hero-description mx-auto" style="max-width: 650px;">
            <span class="text-white-50 fw-light">Cada ferramenta que você precisa usar PDFs, ao seu alcance.</span><br />
            <span class="text-white fw-bold">Todos são 100% GRÁTIS</span>
            <span class="text-white-50 fw-light"> e fáceis de usar!</span>
        </p>
    </section>

    <!-- TOOLS -->
    <section class="tools-section py-4">
        <div class="row g-4">
            <!-- Comprimir PDF -->
            <div class="col-md-3 col-sm-6">
                <a href="/Pdf/Compress" class="text-decoration-none">
                    <div class="tool-card-modern">
                        <div class="tool-icon-bg">
                            <i class="fas fa-file-archive"></i>
                        </div>
                        <div class="tool-number">01</div>
                        <h5 class="tool-title-modern">Comprimir PDF</h5>
                        <p class="tool-desc-modern">Reduza o tamanho do arquivo otimizando a qualidade</p>
                        <div class="tool-line-modern"></div>
                    </div>
                </a>
            </div>

            <!-- Mesclar PDF -->
            <div class="col-md-3 col-sm-6">
                <a href="/Pdf/Merge" class="text-decoration-none">
                    <div class="tool-card-modern">
                        <div class="tool-icon-bg">
                            <i class="fas fa-object-group"></i>
                        </div>
                        <div class="tool-number">02</div>
                        <h5 class="tool-title-modern">Mesclar PDF</h5>
                        <p class="tool-desc-modern">Combine múltiplos PDFs em um único arquivo</p>
                        <div class="tool-line-modern"></div>
                    </div>
                </a>
            </div>

            <!-- Split PDF -->
            <div class="col-md-3 col-sm-6">
                <a href="/Pdf/Split" class="text-decoration-none">
                    <div class="tool-card-modern">
                        <div class="tool-icon-bg">
                            <i class="fas fa-cut"></i>
                        </div>
                        <div class="tool-number">03</div>
                        <h5 class="tool-title-modern">Split PDF</h5>
                        <p class="tool-desc-modern">Separe páginas em arquivos independentes</p>
                        <div class="tool-line-modern"></div>
                    </div>
                </a>
            </div>

            <!-- Converter PDF -->
            <div class="col-md-3 col-sm-6">
                <a href="/Pdf/Convert" class="text-decoration-none">
                    <div class="tool-card-modern">
                        <div class="tool-icon-bg">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <div class="tool-number">04</div>
                        <h5 class="tool-title-modern">Converter PDF</h5>
                        <p class="tool-desc-modern">Converta para Word, Excel, PowerPoint</p>
                        <div class="tool-line-modern"></div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- WHY (sem cards) -->
    <section class="why-section py-5">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="why-item">
                    <div class="why-icon">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h5 class="why-title">Seguro e Privado</h5>
                    <p class="why-description">Nenhum dado é armazenado permanentemente</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-item">
                    <div class="why-icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h5 class="why-title">Rápido e Eficiente</h5>
                    <p class="why-description">Processamento rápido em segundos</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-item">
                    <div class="why-icon">
                        <i class="fas fa-globe"></i>
                    </div>
                    <h5 class="why-title">100% Online</h5>
                    <p class="why-description">Sem instalação, acesse de qualquer lugar</p>
                </div>
            </div>
        </div>
    </section>
</div>