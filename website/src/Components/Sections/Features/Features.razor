@namespace LaPasta.src.Components.Sections.Features

<section class="section features text-center" aria-label="features">
    <div class="container">
        <p class="section-subtitle label-2">@Subtitle</p>
        <h2 class="headline-1 section-title">@Title</h2>

        <ul class="grid-list">
            @foreach (var item in FeatureItems)
            {
                <li class="feature-item">
                    <div class="feature-card">
                        <div class="card-icon">
                            <img src="@item.IconUrl" width="100" height="80" loading="lazy" alt="icon">
                        </div>
                        <h3 class="title-2 card-title">@item.Title</h3>
                        <p class="label-1 card-text">@item.Description</p>
                    </div>
                </li>
            }
        </ul>

        <img src="@Shape1Image" width="208" height="178" loading="lazy" alt="shape" class="shape shape-1">
        <img src="@Shape2Image" width="120" height="115" loading="lazy" alt="shape" class="shape shape-2">
    </div>
</section>